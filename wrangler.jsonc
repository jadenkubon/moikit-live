{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moikit-live",
  "compatibility_date": "2026-07-22",
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "hyperdrive": [
    { "binding": "HYPERDRIVE", "id": "566e67c30a944a638d0f2693f464eab2" }
  ]
}
